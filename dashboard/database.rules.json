{
  "rules": {
    "members": {
      ".read": "auth != null && root.child('members').child(auth.uid).exists()",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid && root.child('members').child($uid).exists()"
      }
    },
    "heartbeat": {
      ".read": "auth != null && root.child('members').child(auth.uid).exists()",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "users": {
      ".read": "auth != null && root.child('members').child(auth.uid).exists()",
