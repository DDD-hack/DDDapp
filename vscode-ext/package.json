{
  "name": "ddd-vscode",
  "displayName": "DDD",
  "description": "DDD companion VS Code extension",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit",
    "package": "vsce package"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/vscode": "^1.120.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^3.9.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
