# Firebase (dashboard)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Daemon Configuration
NEXT_PUBLIC_DAEMON_URL=http://localhost:8765
NEXT_PUBLIC_DAEMON_WS_URL=ws://localhost:8765/ws/vscode

# Daemon -> Firestore (任意・FB-3)
#   サービスアカウント JSON のパス。空のままなら daemon は Firestore 同期を
#   サイレントに無効化してローカルのみで動作する（fail-safe）。
#   path 先頭の "~" は $HOME に展開される。
DDD_FIREBASE_CREDENTIALS=
DDD_FIREBASE_PROJECT_ID=
